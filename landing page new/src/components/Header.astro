---
import { SITE } from '@/data/site';
---

<header class="site-header">
  <div class="container nav-shell">
    <a class="brand" href="/" aria-label="SyntheticBrew home">
      <img class="brand-light" src="/logo-light.png" alt="SyntheticBrew" width="144" height="32" />
      <img class="brand-dark" src="/logo-dark.svg" alt="SyntheticBrew" width="144" height="32" />
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      <details class="nav-dropdown">
        <summary>Features <span aria-hidden="true">⌄</span></summary>
        <div class="nav-panel feature-panel">
          <a href="/features/ai-agent-builder/"><strong>AI Agent Builder</strong><span>Prompt and visual canvas</span></a>
          <a href="/features/multi-agent-orchestration/"><strong>Multi-Agent Orchestration</strong><span>Supervisors and specialists</span></a>
          <a href="/features/mcp-integration/"><strong>MCP Integration</strong><span>Tools with auth context</span></a>
          <a href="/features/agentic-rag/"><strong>Agentic RAG</strong><span>Knowledge-grounded answers</span></a>
          <a href="/knowledge-graphs/"><strong>Knowledge Graphs</strong><span>Typed domain retrieval</span></a>
          <a href="/features/ai-agent-observability/"><strong>Observability</strong><span>Trace and audit every run</span></a>
          <a class="panel-all" href="/#features">Explore all features <span aria-hidden="true">→</span></a>
        </div>
      </details>
      <details class="nav-dropdown">
        <summary>Solutions <span aria-hidden="true">⌄</span></summary>
        <div class="nav-panel">
          <a href="/solutions/customer-service/"><strong>Customer service</strong><span>Grounded support and action</span></a>
          <a href="/solutions/ecommerce/"><strong>Ecommerce</strong><span>Discovery and order support</span></a>
          <a href="/solutions/banking/"><strong>Banking</strong><span>Controlled internal workflows</span></a>
          <a href="/solutions/manufacturing-iot/"><strong>Manufacturing & IoT</strong><span>Operational agents over real data</span></a>
          <a href="/solutions/saas-product-teams/"><strong>SaaS & product teams</strong><span>Headless product integration</span></a>
        </div>
      </details>
      <a href="/pricing/">Pricing</a>
      <a href="/docs/">Docs</a>
      <a href="/blog/">Blog</a>
      <a href="/build/">Services</a>
    </nav>

    <div class="nav-actions">
      <button class="icon-button theme-toggle" type="button" data-theme-toggle aria-label="Use dark theme">
        <svg class="theme-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.41M17.66 6.34l1.41-1.41"/></svg>
        <svg class="theme-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"/></svg>
      </button>
      <a class="nav-login" href="/login">Log in</a>
      <a class="button button-small" href={SITE.cloud} data-analytics="cloud_signup_start">Try Cloud</a>
      <button class="icon-button menu-toggle" type="button" data-menu-toggle aria-label="Open navigation" aria-expanded="false" aria-controls="mobile-menu">
        <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="mobile-menu" data-mobile-menu hidden aria-label="Mobile navigation">
    <div class="container mobile-menu-inner">
      <a href="/#features">Features</a>
      <a href="/#solutions">Solutions</a>
      <a href="/pricing/">Pricing</a>
      <a href="/docs/">Docs</a>
      <a href="/blog/">Blog</a>
      <a href="/build/">Services</a>
      <a href="/login">Log in</a>
      <a href={SITE.cloud}>Try Cloud</a>
    </div>
  </nav>
</header>

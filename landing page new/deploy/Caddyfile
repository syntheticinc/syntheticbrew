syntheticbrew.ai, www.syntheticbrew.ai {
    # Point this root at the versioned output of this standalone Astro project.
    root * /var/www/syntheticbrew-cloud-web-new

    redir /discord https://discord.gg/9yDduSsVWg 302
    # Legacy path: the sitemap has always been served as sitemap-index.xml (robots.txt
    # points there), but /sitemap.xml is a common guess — redirect instead of 404.
    redir /sitemap.xml /sitemap-index.xml 301

    handle /releases/* {
        root * /var/www
        file_server browse
    }

    @docs path /docs /docs/*
    handle @docs {
        root * /var/www/syntheticbrew-docs
        try_files {path} {path}/index.html {path}.html /docs/index.html
        @hashedDocsAssets path /docs/_astro/*
        header @hashedDocsAssets Cache-Control "public, max-age=31536000, immutable"
        @notDocsAssets not path /docs/_astro/*
        header @notDocsAssets Cache-Control "no-cache"
        file_server
    }

    handle /api/* {
        reverse_proxy 127.0.0.1:8080
    }

    handle /demo/api/* {
        uri strip_prefix /demo
        reverse_proxy 127.0.0.1:3000
    }
    handle /demo/* {
        uri strip_prefix /demo
        reverse_proxy 127.0.0.1:3000
    }

    handle /examples/hr-assistant/api/* {
        uri strip_prefix /examples/hr-assistant
        reverse_proxy 127.0.0.1:3001
    }
    handle /examples/support-agent/api/* {
        uri strip_prefix /examples/support-agent
        reverse_proxy 127.0.0.1:3002
    }
    handle /examples/sales-agent/api/* {
        uri strip_prefix /examples/sales-agent
        reverse_proxy 127.0.0.1:3003
    }

    handle /assets/* {
        root * /var/www/syntheticbrew-cloud-web-spa
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    @reactApp path /dashboard /dashboard/* /login /register /forgot-password /reset-password /verify-email /billing /billing/* /settings /team /examples/*
    handle @reactApp {
        root * /var/www/syntheticbrew-cloud-web-spa
        try_files {path} /index.html
        header Cache-Control "no-cache"
        file_server
    }

    handle {
        # Content negotiation: agents sending Accept: text/markdown get the
        # build-generated markdown mirror of each HTML page (scripts/build-markdown-mirrors.mjs).
        # Content-Type must hang off @markdown (evaluated on the original request):
        # Caddy runs header before rewrite, so a `path *.md` matcher would never fire here.
        @markdown {
            header Accept *text/markdown*
            file {
                try_files {path}index.md {path}/index.md
            }
        }
        rewrite @markdown {http.matchers.file.relative}
        header @markdown Content-Type "text/markdown; charset=utf-8"
        header @markdown Vary "Accept"

        @skillDocs path /.well-known/agent-skills/*/SKILL.md
        header @skillDocs Content-Type "text/markdown; charset=utf-8"

        # No homepage fallback: missing marketing URLs reach handle_errors with a real 404 status.
        try_files {path} {path}/index.html
        @astroAssets path /_astro/*
        header @astroAssets Cache-Control "public, max-age=31536000, immutable"
        @notAstroAssets not path /_astro/*
        header @notAstroAssets Cache-Control "no-cache"
        header Link `</.well-known/api-catalog>; rel="api-catalog", </docs>; rel="service-doc", </llms.txt>; rel="alternate"; type="text/markdown", </.well-known/agent-skills/index.json>; rel="agent-skills"`
        @apiCatalog path /.well-known/api-catalog
        header @apiCatalog Content-Type "application/linkset+json"
        @authMd path /auth.md
        header @authMd Content-Type "text/markdown; charset=utf-8"
        @llms path /llms.txt
        header @llms Content-Type "text/plain; charset=utf-8"
        file_server
    }

    handle_errors {
        @notFound expression {http.error.status_code} == 404
        rewrite @notFound /404.html
        file_server
    }

    encode zstd gzip
}

app.syntheticbrew.ai {
    handle /admin/* {
        reverse_proxy 127.0.0.1:9555
    }
    handle /chat/* {
        reverse_proxy 127.0.0.1:9555
    }
    handle /widget/* {
        reverse_proxy 127.0.0.1:9555
    }
    handle /api/* {
        reverse_proxy 127.0.0.1:9555
    }
    @root path /
    redir @root /admin/ 302
    handle {
        reverse_proxy 127.0.0.1:9555
    }
    encode zstd gzip
}

api.syntheticbrew.ai {
    reverse_proxy 127.0.0.1:8080
}

mcp.syntheticbrew.ai {
    reverse_proxy 127.0.0.1:8090
}

# Preserve all legacy ByteBrew redirects during the existing sunset window.
bytebrew.ai, www.bytebrew.ai {
    redir https://syntheticbrew.ai{uri} permanent
}
app.bytebrew.ai {
    redir https://app.syntheticbrew.ai{uri} permanent
}
api.bytebrew.ai {
    redir https://api.syntheticbrew.ai{uri} permanent
}
mcp.bytebrew.ai {
    redir https://mcp.syntheticbrew.ai{uri} permanent
}

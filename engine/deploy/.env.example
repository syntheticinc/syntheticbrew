# SyntheticBrew Engine Configuration
# Copy to .env and edit before running: docker compose up -d

# ============================================================
# LLM Provider
# ============================================================
# Configured post-install via the onboarding wizard on first admin
# login (or later via Admin → Models). Engine does not read LLM
# credentials from env.

# ============================================================
# Auth
# ============================================================
# "local"    — engine auto-generates an Ed25519 keypair on first boot (single-replica only).
# "external" — engine validates JWTs using a pre-provisioned public key.
SYNTHETICBREW_AUTH_MODE=local

# Used when SYNTHETICBREW_AUTH_MODE=local (must be a persistent volume mount)
SYNTHETICBREW_JWT_KEYS_DIR=/var/lib/syntheticbrew/keys

# Used when SYNTHETICBREW_AUTH_MODE=external (path to hex-encoded Ed25519 public key file)
# SYNTHETICBREW_JWT_PUBLIC_KEY_PATH=/etc/syntheticbrew/jwt_ed25519.pub

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_PASSWORD=syntheticbrew

# ============================================================
# Engine
# ============================================================
ENGINE_PORT=8443

# ============================================================
# Bridge (optional, for mobile connectivity)
# ============================================================
# BRIDGE_ENABLED=true
# BRIDGE_URL=wss://bridge.syntheticbrew.ai
# BRIDGE_AUTH_TOKEN=your-token

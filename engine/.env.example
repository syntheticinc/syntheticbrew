# SyntheticBrew Engine — environment variables reference.
#
# Every variable here corresponds to a const in pkg/config/env_vars.go and a
# typed field on BootstrapConfig. They are bound via Viper in LoadBootstrap,
# so YAML and env can be mixed: env wins over YAML wins over built-in default.
#
# Anything not listed here is unsupported and will be rejected by review.
# See `.claude/rules/code-review.md` for the env-vars policy.
#
# LLM provider credentials are NOT in this file. Configure providers via the
# first-run onboarding wizard or Admin → Models — engine never reads LLM API
# keys from env (a stale env key produces opaque 401s on the first chat turn).

# ── Required (no YAML fallback) ───────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/syntheticbrew?sslmode=disable

# ── Engine listener ──────────────────────────────────────────────────────────
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8443
SYNTHETICBREW_INTERNAL_PORT=             # 0 / unset = single-port mode; set to enable two-port split
SYNTHETICBREW_CORS_ORIGINS=              # Comma-separated; empty = allow all

# ── Auth (Ed25519) ───────────────────────────────────────────────────────────
SYNTHETICBREW_AUTH_MODE=local            # "local" or "external"
SYNTHETICBREW_JWT_KEYS_DIR=              # Default: <data_dir>/keys (local mode)
SYNTHETICBREW_JWT_PUBLIC_KEY_PATH=       # Required when auth_mode=external
SYNTHETICBREW_LOCAL_SESSION_TTL=1h       # Local-mode admin session lifetime; Go duration format

# ── Embeddings (Ollama-style) ────────────────────────────────────────────────
EMBED_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# ── MCP catalog overrides ────────────────────────────────────────────────────
SYNTHETICBREW_DOCS_MCP_URL=              # Override URL for the seeded syntheticbrew-docs MCP server

# ── LSP installer ────────────────────────────────────────────────────────────
SYNTHETICBREW_DISABLE_LSP_DOWNLOAD=false # Skip downloading LSP servers (use system PATH only)

# ── Update checker ───────────────────────────────────────────────────────────
SYNTHETICBREW_VERSIONS_URL=              # Override versions endpoint (default: api.syntheticbrew.ai/api/v1/versions/engine)

# ── Debug / development ──────────────────────────────────────────────────────
SYNTHETICBREW_DEBUG_MODEL=               # Directory to dump every LLM request/response (debug only)

# ── Bootstrap admin token (k8s / automation) ─────────────────────────────────
# When set, engine seeds an admin API token in api_tokens table on first boot
# (idempotent — skipped when name="bootstrap-admin" already exists). Use this
# to enable automated config-apply via brewctl in CI/CD without manual UI flow.
# Format: bb_<64 lowercase hex chars>
# Generate: echo "bb_$(openssl rand -hex 32)"
# SYNTHETICBREW_BOOTSTRAP_ADMIN_TOKEN=

# ── MCP server secrets ───────────────────────────────────────────────────────
# Per-MCP API keys are referenced by env-var name from mcp_servers.auth_key_env
# (legacy single-tenant pointer pattern). Set whichever names your admin UI
# entries reference. Target architecture: per-tenant encrypted storage in DB
# (mirrors models.api_key_encrypted) — tracked as separate plan.

